# Copie este arquivo para .env e preencha suas credenciais
TB_URL=https://mhocloud.com
TB_USERNAME=seu_email@exemplo.com
TB_PASSWORD=sua_senha

# Caminho do banco SQLite (padrão: neutramol.db na mesma pasta)
DB_PATH=neutramol.db

# Janela de histórico inicial em dias (usado na 1ª sincronização)
HISTORY_DAYS=30
